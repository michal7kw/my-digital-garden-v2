---
pagination:
  data: collections.gardenIndexes
  size: 1
  alias: garden
permalink: /garden/{{ garden.username }}/dashboard/
eleventyExcludeFromCollections: true
---
{% import "components/dashboardMacros.njk" as dm %}
{% set safeNotes = garden.notes | excludePersonal %}
{% set typeCounts = safeNotes | countByType %}
{% set biomarkers = safeNotes | filterByType("biomarker") %}
{% set supplements = safeNotes | filterByType("supplement") %}
{% set conditions = safeNotes | filterByType("condition") %}
{% set interventions = safeNotes | filterByType("intervention") %}
{% set labtests = safeNotes | filterByType("labtest") %}
{% set recent = safeNotes | sortByUpdated %}
{% set topTagList = safeNotes | topTags(15) %}
{% set mostConnected = safeNotes | sortByTagCount | limit(8) %}
<!DOCTYPE html>
<html lang="{{ meta.mainLanguage }}">
  <head>
    <title>{{ garden.username }}'s Health Dashboard</title>
    {% include "components/pageheader.njk" %}
  </head>
  <body class="theme-{{ meta.baseTheme }} markdown-preview-view">
    {% include "components/navbar.njk" %}

    <main class="dashboard">
      <header class="dashboard-header">
        <button type="button"
                class="theme-toggle"
                aria-label="Toggle colour scheme"
                title="Toggle light / dark theme"
                onclick="(function(){var c=document.body.classList;var next=c.contains('theme-light')?'dark':'light';c.remove('theme-dark','theme-light');c.add('theme-'+next);try{localStorage.setItem('mkg-theme',next);}catch(e){}})()">
          <i icon-name="sun-moon"></i>
        </button>
        <h1>{{ garden.username }}'s Health Dashboard</h1>
        <p class="dashboard-meta">
          <a href="/garden/{{ garden.username }}/">&larr; Back to garden home</a>
          {% if garden.lastUpdated %}
            &nbsp;&middot;&nbsp;
            <span>Last activity: <span class="human-date" data-date="{{ garden.lastUpdated }}"></span></span>
          {% endif %}
        </p>
      </header>

      <div class="medical-disclaimer">
        <strong>For research &amp; informational purposes only.</strong> Not medical advice.
        Always consult a qualified clinician before acting on anything you read here.
      </div>

      {# ── Inline client-side search (uses a small embedded catalog of title/type/permalink/tags) ── #}
      {% if safeNotes.length > 0 %}
      <section class="section dashboard-search"
               x-data="{ q: '', activeTag: '' }">
        <form class="dash-search-form" role="search" @submit.prevent>
          <label for="dash-search" class="dash-search-label">Search this dashboard</label>
          <input id="dash-search"
                 type="search"
                 autocomplete="off"
                 placeholder="Type a biomarker, supplement, condition…"
                 x-model="q" />
          <span class="dash-search-hint" x-show="q.length >= 1" x-cloak>
            <span x-text="q.length < 2 ? 'Keep typing…' : 'Press enter to jump to first match'"></span>
          </span>
        </form>

        {# ── Tag filter chips (top 15 most-common tags on this garden) ── #}
        {% if topTagList.length > 0 %}
        <div class="tag-chip-row" aria-label="Filter by tag">
          <button type="button"
                  class="tag-chip"
                  :class="activeTag === '' ? 'is-active' : ''"
                  @click="activeTag = ''">All</button>
          {% for pair in topTagList %}
            <button type="button"
                    class="tag-chip"
                    data-tag="{{ pair[0] }}"
                    :class="activeTag === '{{ pair[0] }}' ? 'is-active' : ''"
                    @click="activeTag === '{{ pair[0] }}' ? activeTag = '' : activeTag = '{{ pair[0] }}'">
              #{{ pair[0] }} <span class="tag-chip-count">{{ pair[1] }}</span>
            </button>
          {% endfor %}
        </div>
        {% endif %}

        {#
          Catalog is NOT inlined (would bloat HTML by ~400KB for 1000 notes).
          Instead, the script below lazily fetches the existing /searchIndex.json
          on first keystroke. It's already generated by search-index.njk and used
          by the full /search/ page — a natural cache hit across pages.
        #}

        {# Live results area (results + filtered cards hidden until user types) #}
        <div class="dash-search-results" x-show="q.length >= 2" x-cloak>
          <ul id="dash-search-hits" class="dash-search-hits"></ul>
        </div>
      </section>
      {% endif %}

      {% if safeNotes.length == 0 %}
        <div class="empty-state">
          <p>No published entities yet. Start publishing curated notes to populate this dashboard.</p>
        </div>
      {% else %}

      <section class="section" aria-label="Summary statistics">
        <div class="stat-grid">
          {{ dm.statCard("Biomarkers", typeCounts.biomarker, "tracked markers", "#biomarkers") }}
          {{ dm.statCard("Supplements", typeCounts.supplement, "in regimen library", "#supplements") }}
          {{ dm.statCard("Conditions", typeCounts.condition, "monitored", "#conditions") }}
          {{ dm.statCard("Interventions", typeCounts.intervention, "lifestyle &amp; therapy", "#interventions") }}
        </div>
      </section>

      {% if biomarkers.length > 0 %}
      <section class="section" id="biomarkers">
        <div class="section-header">
          <h2>Biomarker Watchlist</h2>
          <a class="section-link" href="/garden/{{ garden.username }}/#biomarker">Browse all &rarr;</a>
        </div>
        <div class="card-list">
          {% for note in biomarkers | limit(12) %}
            {{ dm.entryCard(dm.entryPermalink(note, garden.username, "biomarker"), note.data.title or note.fileSlug, note.data.description, note.data.tags) }}
          {% endfor %}
        </div>
      </section>
      {% endif %}

      {% if supplements.length > 0 %}
      <section class="section" id="supplements">
        <div class="section-header">
          <h2>Current Regimen &middot; Supplements</h2>
          <a class="section-link" href="/garden/{{ garden.username }}/#supplement">Browse all &rarr;</a>
        </div>
        <div class="card-list">
          {% for note in supplements | limit(12) %}
            {{ dm.entryCard(dm.entryPermalink(note, garden.username, "supplement"), note.data.title or note.fileSlug, note.data.description, note.data.tags) }}
          {% endfor %}
        </div>
      </section>
      {% endif %}

      {% if conditions.length > 0 %}
      <section class="section" id="conditions">
        <div class="section-header">
          <h2>Tracked Conditions</h2>
          <a class="section-link" href="/garden/{{ garden.username }}/#condition">Browse all &rarr;</a>
        </div>
        <div class="card-list">
          {% for note in conditions | limit(8) %}
            {{ dm.entryCard(dm.entryPermalink(note, garden.username, "condition"), note.data.title or note.fileSlug, note.data.description, []) }}
          {% endfor %}
        </div>
      </section>
      {% endif %}

      {% if interventions.length > 0 %}
      <section class="section" id="interventions">
        <div class="section-header">
          <h2>Interventions</h2>
          <a class="section-link" href="/garden/{{ garden.username }}/#intervention">Browse all &rarr;</a>
        </div>
        <div class="card-list">
          {% for note in interventions | limit(8) %}
            {{ dm.entryCard(dm.entryPermalink(note, garden.username, "intervention"), note.data.title or note.fileSlug, note.data.description, []) }}
          {% endfor %}
        </div>
      </section>
      {% endif %}

      {% if mostConnected.length > 0 %}
      <section class="section" id="most-connected">
        <div class="section-header">
          <h2>Most Connected</h2>
          <span class="section-link">Entities with the densest tag overlap — good places to start exploring</span>
        </div>
        <ul class="recent-list">
          {% for note in mostConnected %}
            {% set permalink = note.data.permalink or ("/garden/" + garden.username + "/" + (note.data.entityType or "note") + "/" + (note.data.slug or note.fileSlug) + "/") %}
            <li>
              <span class="pill">{{ note.data.entityType or "note" }}</span>
              <a href="{{ permalink }}">{{ note.data.title or note.fileSlug }}</a>
              {% if note.data.tags and note.data.tags.length > 0 %}
                <span class="date">{{ note.data.tags.length }} tag{% if note.data.tags.length != 1 %}s{% endif %}</span>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </section>
      {% endif %}

      {% if recent.length > 0 %}
      <section class="section">
        <div class="section-header">
          <h2>Recent Activity</h2>
        </div>
        <ul class="recent-list">
          {% for note in recent | limit(8) %}
            {% set permalink = note.data.permalink or ("/garden/" + garden.username + "/" + (note.data.entityType or "note") + "/" + (note.data.slug or note.fileSlug) + "/") %}
            <li>
              <span class="pill">{{ note.data.entityType or "note" }}</span>
              <a href="{{ permalink }}">{{ note.data.title or note.fileSlug }}</a>
              {% if note.data.updated %}
                <span class="date human-date" data-date="{{ note.data.updated }}"></span>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </section>
      {% endif %}

      <section class="section">
        <div class="section-header">
          <h2>Quick Links</h2>
        </div>
        <div class="quick-links">
          <a href="/garden/{{ garden.username }}/">Garden home</a>
          <a href="/graph-explorer/">Graph explorer</a>
          <a href="/search/">Full search</a>
          <a href="/feed.xml">RSS feed</a>
          {% if labtests.length > 0 %}
            <a href="/garden/{{ garden.username }}/#labtest">Lab tests ({{ labtests.length }})</a>
          {% endif %}
        </div>
      </section>

      {% endif %}
    </main>

    {# ── Dashboard search + tag-filter — lazy-fetches /searchIndex.json ── #}
    <script>
      (function () {
        var input = document.getElementById('dash-search');
        var hitsEl = document.getElementById('dash-search-hits');
        var catalog = null;
        var catalogLoading = null;

        // Derive entity type from URL path /garden/{user}/{type}/{slug}/
        function typeFromUrl(u) {
          var m = /\/garden\/[^/]+\/([^/]+)\//.exec(u || '');
          return m ? m[1] : '';
        }

        function loadCatalog() {
          if (catalog) return Promise.resolve(catalog);
          if (catalogLoading) return catalogLoading;
          catalogLoading = fetch('/searchIndex.json')
            .then(function (r) { return r.ok ? r.json() : []; })
            .then(function (items) { catalog = Array.isArray(items) ? items : []; return catalog; })
            .catch(function () { catalog = []; return catalog; });
          return catalogLoading;
        }

        function scoreItem(it, q) {
          if (!q) return 0;
          var hay = (it.title + ' ' + (it.tags || []).join(' ')).toLowerCase();
          var tokens = q.toLowerCase().split(/\s+/).filter(Boolean);
          if (!tokens.every(function (t) { return hay.indexOf(t) !== -1; })) return 0;
          var prefix = it.title.toLowerCase().indexOf(q.toLowerCase()) === 0 ? 10 : 0;
          return prefix + tokens.length;
        }

        function render(q) {
          if (!hitsEl) return;
          if (!q || q.length < 2) { hitsEl.innerHTML = ''; return; }
          var scored = catalog
            .map(function (it) { return { it: it, s: scoreItem(it, q) }; })
            .filter(function (x) { return x.s > 0; })
            .sort(function (a, b) { return b.s - a.s; })
            .slice(0, 12);
          if (scored.length === 0) {
            hitsEl.innerHTML = '<li class="dash-search-empty">No matches. Try <a href="/search/?q=' + encodeURIComponent(q) + '">full search</a>.</li>';
            return;
          }
          hitsEl.innerHTML = scored.map(function (x) {
            var it = x.it;
            var t = typeFromUrl(it.url) || 'note';
            return '<li class="dash-search-hit"><a href="' + it.url + '"><span class="pill">' + t + '</span> <strong>' + it.title + '</strong></a></li>';
          }).join('');
        }

        if (input) {
          input.addEventListener('input', function (e) {
            var q = e.target.value;
            loadCatalog().then(function () { render(q); });
          });
          input.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') {
              var first = hitsEl && hitsEl.querySelector('a');
              if (first) { e.preventDefault(); window.location = first.getAttribute('href'); }
            }
          });
        }

        // ── Tag filter: dim non-matching entry cards when a chip is active ──
        var chipRow = document.querySelector('.tag-chip-row');
        if (chipRow) {
          chipRow.addEventListener('click', function (e) {
            var btn = e.target.closest('.tag-chip');
            if (!btn) return;
            var tag = btn.getAttribute('data-tag') || '';
            document.querySelectorAll('.card-list .entry-card').forEach(function (card) {
              if (!tag) { card.classList.remove('is-dimmed'); return; }
              var text = card.textContent.toLowerCase();
              card.classList.toggle('is-dimmed', text.indexOf('#' + tag.toLowerCase()) === -1);
            });
          });
        }
      })();
    </script>

    {% include "components/timestamps.njk" %}
    {% include "components/lucideIcons.njk" %}
    {% for imp in dynamics.common.footer %}
      {% include imp %}
    {% endfor %}
  </body>
</html>
